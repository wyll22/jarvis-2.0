# ══════════════════════════════════════════════════════════════
# J.A.R.V.I.S. — Variáveis de Ambiente (Backend)
# Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════════════════════════════

PORT=3001

# =========================
# AUTENTICAÇÃO DO PAINEL
# =========================
ADMIN_PASSWORD=TROQUE_ESTA_SENHA_FORTE
ALLOWED_JID=556198705105

# =========================
# SUPABASE
# =========================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =========================
# WHATSAPP
# =========================
JAVIS_ALLOWED_JID=556198705105@s.whatsapp.net
WHATSAPP_AUTO_START=true
WHATSAPP_AUDIO_ENABLED=true
WHATSAPP_INCOMING_AUDIO_ENABLED=true

# =========================
# IA — Cascade (Gemini > OpenRouter > Groq > Mistral)
# =========================
AI_PROVIDER_ORDER=gemini,openrouter,groq,mistral,cerebras,sambanova,deepseek
AI_REQUEST_TIMEOUT_MS=30000

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo

# =========================
# VOZ (OpenAI TTS — opcional)
# =========================
OPENAI_API_KEY=

# =========================
# BUSCA WEB (opcional)
# =========================
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PRIMARY=serper
SERPER_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# =========================
# BRIEFING DIÁRIO
# =========================
DAILY_BRIEFING_ENABLED=true
DAILY_BRIEFING_TIME=07:00
APPOINTMENT_ALERTS_ENABLED=true